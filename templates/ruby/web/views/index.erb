<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @app_name %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #0d0d0d; color: #e0dcd7; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; }
    h1 { background: linear-gradient(135deg, #fab283, #fc533a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-size: 3rem; }
    p { margin-top: 1rem; color: #888; }
    .time { margin-top: 2rem; font-size: 0.9rem; color: #555; }
  </style>
</head>
<body>
  <h1><%= @app_name %></h1>
  <% if @greeting %>
    <p><%= @greeting %></p>
  <% else %>
    <p>Welcome to your Sinatra web app.</p>
  <% end %>
  <p class="time"><%= @time %></p>
</body>
</html>
